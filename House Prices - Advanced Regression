 model.","metadata":{}},{"id":"d8267d68-741b-442a-98d7-8a23b017b60e","cell_type":"code","source":"from sklearn.ensemble import GradientBoostingRegressor","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-29T00:21:37.425918Z","iopub.execute_input":"2026-04-29T00:21:37.426206Z","iopub.status.idle":"2026-04-29T00:21:37.430847Z","shell.execute_reply.started":"2026-04-29T00:21:37.426183Z","shell.execute_reply":"2026-04-29T00:21:37.429629Z"}},"outputs":[],"execution_count":33},{"id":"865f9782-d72d-4de1-b808-00f065bb7529","cell_type":"code","source":"gb_feature_engineered = Pipeline(steps=[\n    (\"preprocessor\", preprocessor_fe),\n    (\"model\", GradientBoostingRegressor(random_state=42))\n])\n\ngb_feature_engineered.fit(X_train_fe, y_train)\n\ngb_fe_predictions = gb_feature_engineered.predict(X_val_fe)\n\ngb_fe_mae = mean_absolute_error(y_val, gb_fe_predictions)\ngb_fe_mse = mean_squared_error(y_val, gb_fe_predictions)\ngb_fe_rmse = gb_fe_mse ** 0.5\ngb_fe_r2 = r2_score(y_val, gb_fe_predictions)\n\nprint(f\"Gradient Boosting with feature engineering MAE:  {gb_fe_mae:,.2f}\")\nprint(f\"Gradient Boosting with feature engineering RMSE: {gb_fe_rmse:,.2f}\")\nprint(f\"Gradient Boosting with feature engineering R2:   {gb_fe_r2:.4f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-29T00:21:56.401894Z","iopub.execute_input":"2026-04-29T00:21:56.402159Z","iopub.status.idle":"2026-04-29T00:21:57.368903Z","shell.execute_reply.started":"2026-04-29T00:21:56.402135Z","shell.execute_reply":"2026-04-29T00:21:57.367877Z"}},"outputs":[{"name":"stdout","text":"Gradient Boosting with feature engineering MAE:  16,360.47\nGradient Boosting with feature engineering RMSE: 26,974.12\nGradient Boosting with feature engineering R2:   0.9051\n","output_type":"stream"}],"execution_count":34},{"id":"0b167239-17fe-469f-ba49-267d0b3e55f2","cell_type":"markdown","source":"## Step 21 - Compare model families\n\nNow we compare model families using the same feature-engineered data.\n\nThis tells us whether changing the model improved performance more than changing the features.","metadata":{}},{"id":"bcca8c51-24f4-4185-8651-0e2c64797d4e","cell_type":"code","source":"model_family_comparison = pd.DataFrame({\n    \"model\": [\n        \"Average price baseline\",\n        \"Random Forest baseline\",\n        \"Random Forest feature engineered\",\n        \"Gradient Boosting feature engineered\"\n    ],\n    \"MAE\": [baseline_mae, rf_mae, rf_fe_mae, gb_fe_mae],\n    \"RMSE\": [baseline_rmse, rf_rmse, rf_fe_rmse, gb_fe_rmse],\n    \"R2\": [baseline_r2, rf_r2, rf_fe_r2, gb_fe_r2]\n})\n\nmodel_family_comparison","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-29T00:22:06.382064Z","iopub.execute_input":"2026-04-29T00:22:06.382337Z","iopub.status.idle":"2026-04-29T00:22:06.391184Z","shell.execute_reply.started":"2026-04-29T00:22:06.382313Z","shell.execute_reply":"2026-04-29T00:22:06.390375Z"}},"outputs":[{"execution_count":35,"output_type":"execute_result","data":{"text/plain":"                                  model           MAE          RMSE        R2\n0                Average price baseline  62575.926452  87619.034506 -0.000882\n1                Random Forest baseline  17492.431747  29063.041250  0.889879\n2      Random Forest feature engineered  17560.711764  29900.511127  0.883442\n3  Gradient Boosting feature engineered  16360.466551  26974.120016  0.905141","text/html":"<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border=\"1\" class=\"dataframe\">\n  <thead>\n    <tr style=\"text-align: right;\">\n      <th></th>\n      <th>model</th>\n      <th>MAE</th>\n      <th>RMSE</th>\n      <th>R2</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>0</th>\n      <td>Average price baseline</td>\n 